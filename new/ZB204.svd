<device schemaVersion="1.2" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
	<vendor>GS</vendor>
	<!-- device vendor name -->
	<vendorID>lsz</vendorID>
	<!-- device vendor short name -->
	<name>ZB204</name>
	<!-- name of part-->
	<!--
	<series>ARMCM</series>
	-->
	<!-- device series the device belongs to -->
	<version>1.2</version>
	<!-- version of this description, adding CMSIS-SVD 1.1 tags -->
	<description>ARM 32-bit Cortex-M4 Microcontroller based device, CPU clock up to 80MHz, etc. </description>
	<licenseText>
		<!-- this license text will appear in header file. \n force line breaks -->
    ARM Limited (ARM) is supplying this software for use with Cortex-M\n
    processor based microcontroller, but can be equally used for other\n
    suitable  processor architectures. This file can be freely distributed.\n
    Modifications to this file shall be clearly marked.\n
    \n
    THIS SOFTWARE IS PROVIDED "AS IS".  NO WARRANTIES, WHETHER EXPRESS, IMPLIED\n
    OR STATUTORY, INCLUDING, BUT NOT LIMITED TO, IMPLIED WARRANTIES OF\n
    MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE APPLY TO THIS SOFTWARE.\n
    ARM SHALL NOT, IN ANY CIRCUMSTANCES, BE LIABLE FOR SPECIAL, INCIDENTAL, OR\n
    CONSEQUENTIAL DAMAGES, FOR ANY REASON WHATSOEVER.
  </licenseText>
	<cpu>
		<!-- details about the cpu embedded in the device -->
		<name>CM3</name>
		<revision>r2p0</revision>
		<endian>little</endian>
		<mpuPresent>true</mpuPresent>
		<fpuPresent>false</fpuPresent>
		<vtorPresent>true</vtorPresent>
		<nvicPrioBits>3</nvicPrioBits>
		<vendorSystickConfig>false</vendorSystickConfig>
	</cpu>
	<addressUnitBits>8</addressUnitBits>
	<!-- byte addressable memory -->
	<width>32</width>
	<!-- bus width is 32 bits -->
	<!-- default settings implicitly inherited by subsequent sections -->
	<size>32</size>
	<!-- this is the default size (number of bits) of all peripherals
                                                                       and register that do not define "size" themselves -->
	<access>read-write</access>
	<!-- default access permission for all subsequent registers -->
	<resetValue>0x00000000</resetValue>
	<!-- by default all bits of the registers are initialized to 0 on reset -->
	<resetMask>0xFFFFFFFF</resetMask>
	<!-- by default all 32Bits of the registers are used -->
	<peripherals>
		<peripheral>
			<name>RESET</name>
			<description>Reset Controller Module</description>
			<baseAddress>0x40020000</baseAddress>
			<addressBlock>
				<offset>0</offset>
				<size>0x4</size>
				<usage>registers</usage>
			</addressBlock>
			<registers>
				<register>
					<name>RCR</name>
					<description>Reset Control Register</description>
					<addressOffset>0x3</addressOffset>
					<size>8</size>
					<fields>
						<field>
							<name>FRCRSTOUT</name>
							<description>Force RESET PIN</description>
							<bitOffset>0</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>Negate</name>
									<description>Negate bit</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>Assert</name>
									<description>Assert bit</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
					</fields>
				</register>
				<register>
					<name>RSR</name>
					<description>Reset Status Register</description>
					<addressOffset>0x2</addressOffset>
					<size>8</size>
					<fields>
						<field>
							<name>POR</name>
							<description>Watchdog Enable Bit</description>
							<bitOffset>1</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-only</access>
						</field>
						<field>
							<name>STDBYWKR</name>
							<description>Standby Wakeup Reset Flag</description>
							<bitOffset>2</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-only</access>
						</field>
						<field>
							<name>FPOR</name>
							<description>Force Power-On Reset Flag</description>
							<bitOffset>3</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-only</access>
						</field>
						<field>
							<name>WDR</name>
							<description>Watchdog Change Update Bit</description>
							<bitOffset>4</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-only</access>
						</field>
						<field>
							<name>SOFT</name>
							<description>Watchdog Change Update Bit</description>
							<bitOffset>5</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-only</access>
						</field>
						<field>
							<name>PVD</name>
							<description>Watchdog Interrupt Flag Bit</description>
							<bitOffset>6</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-only</access>
						</field>
						<field>
							<name>ERST</name>
							<description>Watchdog Timer Prescaler</description>
							<bitOffset>7</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
						</field>
					</fields>
				</register>
				<register>
					<name>RTR</name>
					<description>Reset Test Register</description>
					<addressOffset>0x1</addressOffset>
					<size>8</size>
					<fields>
						<field>
							<name>FPOR</name>
							<description>Force Power On Reset</description>
							<bitOffset>0</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
						</field>
						<field>
							<name>TEST</name>
							<description>Write Access Enable Sequence Input</description>
							<bitOffset>6</bitOffset>
							<bitWidth>2</bitWidth>
							<access>read-write</access>
						</field>
					</fields>
				</register>
			</registers>
		</peripheral>
		<peripheral>
			<name>SWT</name>
			<description>Software Watchdog Timer</description>
			<baseAddress>0x401E0000</baseAddress>
			<addressBlock>
				<offset>0</offset>
				<size>0x20</size>
				<usage>registers</usage>
			</addressBlock>
			<interrupt>
				<name>SWT</name>
				<description>SWT interrupt</description>
				<value>16</value>
			</interrupt>
			<registers>
				<register>
					<name>SWTCR</name>
					<description>SWT Control Register</description>
					<addressOffset>0x0</addressOffset>
					<size>32</size>
					<fields>
						<field>
							<name>WEN</name>
							<description>Watchdog Enable Bit</description>
							<bitOffset>0</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>disabled</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>enabled</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>FRZ</name>
							<description>Watchdog Change Update Bit</description>
							<bitOffset>1</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>continues to run</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>stopped</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>STP</name>
							<description>Watchdog Change Update Bit</description>
							<bitOffset>2</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>continues to run</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>stopped</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>CSL</name>
							<description>Watchdog Interrupt Flag Bit</description>
							<bitOffset>3</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>System</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>Oscillator</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>SLK</name>
							<description>Watchdog Timer Prescaler</description>
							<bitOffset>4</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>read/write</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>read-only</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>HLK</name>
							<description>Watchdog Clock Domain Interrupt Status Bit</description>
							<bitOffset>5</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>read/write</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>read-only</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>ITR</name>
							<description>Debug Mode Bit</description>
							<bitOffset>6</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>reset</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>interrupt</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>WND</name>
							<description>STOP Mode Bit</description>
							<bitOffset>7</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>Regular mode</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>Windowed mode</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>RIA</name>
							<description>Doze Mode Bit</description>
							<bitOffset>8</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>generates a bus error</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>causes a system reset if WEN=1</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>KEY</name>
							<description>Wait Mode Bit</description>
							<bitOffset>9</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>Fixed Service</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>Keyed Service</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>MAP</name>
							<description>Wait Mode Bit</description>
							<bitOffset>24</bitOffset>
							<bitWidth>8</bitWidth>
							<access>read-write</access>
						</field>
					</fields>
				</register>
				<register>
					<name>SWTIR</name>
					<description>SWT Interrupt Register</description>
					<addressOffset>0x4</addressOffset>
					<size>32</size>
					<fields>
						<field>
							<name>TIF</name>
							<description>Timeout Interrupt Flag</description>
							<bitOffset>0</bitOffset>
							<bitWidth>1</bitWidth>
							<access>read-write</access>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>No interrupt</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>Interrupt request</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
					</fields>
				</register>
				<register>
					<name>SWTTO</name>
					<description>SWT Timeout Register</description>
					<addressOffset>0x8</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>SWTWN</name>
					<description>SWT Window Register</description>
					<addressOffset>0xC</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>SWTSR</name>
					<description>SWT Service Register</description>
					<addressOffset>0x10</addressOffset>
					<size>32</size>
					<fields>
						<field>
							<name>WSC</name>
							<description>Watchdog Service Code</description>
							<bitOffset>0</bitOffset>
							<bitWidth>16</bitWidth>
							<access>read-write</access>
						</field>
					</fields>
				</register>
				<register>
					<name>SWTCO</name>
					<description>SWT Counter Output Register</description>
					<addressOffset>0x14</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>SWTSK</name>
					<description>SWT Service Key Register</description>
					<addressOffset>0x18</addressOffset>
					<size>32</size>
					<fields>
						<field>
							<name>SK</name>
							<description>Service Key</description>
							<bitOffset>0</bitOffset>
							<bitWidth>16</bitWidth>
							<access>read-write</access>
						</field>
					</fields>
				</register>
			</registers>
		</peripheral>
		<peripheral>
			<name>AES</name>
			<description>AES</description>
			<baseAddress>0x40600000</baseAddress>
			<addressBlock>
				<offset>0</offset>
				<size>0x50</size>
				<usage>registers</usage>
			</addressBlock>
			<interrupt>
				<name>AES</name>
				<description>AES interrupt</description>
				<value>13</value>
			</interrupt>
			<registers>
				<register>
					<name>DIOR</name>
					<description>DIOR</description>
					<addressOffset>0x0</addressOffset>
					<size>32</size>
				</register>
				<register>
					<dim>8</dim>
					<dimIncrement>4</dimIncrement>
					<name>KEY[%s]</name>
					<description>KEY[%s]</description>
					<addressOffset>0x10</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>CSR</name>
					<description>CSR</description>
					<addressOffset>0x30</addressOffset>
					<size>32</size>
				</register>
				<register>
					<dim>4</dim>
					<dimIncrement>4</dimIncrement>
					<name>COUNTER[%s]</name>
					<description>COUNTER[%s]</description>
					<addressOffset>0x34</addressOffset>
					<size>32</size>
				</register>
			</registers>
		</peripheral>
		<peripheral>
			<name>CRC</name>
			<description>CRC</description>
			<baseAddress>0x40400000</baseAddress>
			<addressBlock>
				<offset>0</offset>
				<size>0x10</size>
				<usage>registers</usage>
			</addressBlock>
			<registers>
				<register>
					<name>CTR</name>
					<description>CTR</description>
					<addressOffset>0x0</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>RES</name>
					<description>RES</description>
					<addressOffset>0x4</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>INI</name>
					<description>INI</description>
					<addressOffset>0x8</addressOffset>
					<size>32</size>
				</register>
				<register>
					<name>DATI</name>
					<description>DATI</description>
					<addressOffset>0xc</addressOffset>
					<size>32</size>
				</register>
			</registers>
		</peripheral>
		<peripheral>
			<name>ADC</name>
			<description>Analog-to-digital converter</description>
			<baseAddress>0x40060000</baseAddress>
			<addressBlock>
				<offset>0</offset>
				<size>0x50</size>
				<usage>registers</usage>
			</addressBlock>
			<registers>
				<register>
					<name>ADCISR</name>
					<description>ADC interrupt and status register</description>
					<addressOffset>0x0</addressOffset>
					<size>32</size>
					<fields>
						<field>
							<name>ADRDY</name>
							<description>ADC ready</description>
							<bitOffset>0</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>not yet ready</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>ready</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>EOSMP</name>
							<description>End of sampling flag</description>
							<bitOffset>1</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>Not end</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>End</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>EOC</name>
							<description>End of conversion flag</description>
							<bitOffset>2</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>not complete</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>complete</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>EOSEQ</name>
							<description>End of sequence flag</description>
							<bitOffset>3</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>not complete</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>complete</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>OVR</name>
							<description>ADC overrun</description>
							<bitOffset>4</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>No</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>Overrun</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>FULL</name>
							<description>FIFO full status</description>
							<bitOffset>5</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>not full</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
									<description>full</description>
									<value>1</value>
								</enumeratedValue>
							</enumeratedValues>
						</field>
						<field>
							<name>EMPTY</name>
							<description>FIFO empty status</description>
							<bitOffset>6</bitOffset>
							<bitWidth>1</bitWidth>
							<enumeratedValues>
								<enumeratedValue>
									<name>0</name>
									<description>not empty</description>
									<value>0</value>
								</enumeratedValue>
								<enumeratedValue>
									<name>1</name>
